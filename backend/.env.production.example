# Production Environment Variables for Render

# Node Environment
NODE_ENV=production
PORT=5000

# Database
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/georgetown-traffic?retryWrites=true&w=majority

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# CORS Configuration
CORS_ORIGIN=https://your-frontend-url.onrender.com

# Python AI Service (Optional)
PYTHON_AI_SERVICE_URL=https://your-python-service-url.onrender.com

# Request Configuration
MAX_REQUEST_SIZE=10mb
REQUEST_TIMEOUT=30000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Redis (Optional - for Bull queue)
# REDIS_URL=redis://your-redis-url

# Security
ENABLE_HTTPS=false
# API_KEY=your-api-key-for-service-to-service-communication
