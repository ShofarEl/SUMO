# Georgetown Traffic AI - Environment Configuration
# Copy this file to .env and update with your actual values

# ======================
# Frontend Configuration
# ======================
VITE_API_URL=http://localhost:5000
VITE_WS_URL=ws://localhost:5000
VITE_ENV=development

# ======================
# Backend Configuration
# ======================
NODE_ENV=development
PORT=5000

# Database
MONGODB_URI=mongodb://mongodb:27017/georgetown-traffic-ai

# Redis
REDIS_URL=redis://redis:6379

# JWT Authentication
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRE=7d
JWT_REFRESH_EXPIRE=30d

# Python AI Service
PYTHON_AI_SERVICE_URL=http://python-ai:8000

# CORS
CORS_ORIGIN=http://localhost:3000

# Logging
LOG_LEVEL=info

# ======================
# Python AI Configuration
# ======================
ENVIRONMENT=development
HOST=0.0.0.0
PYTHON_PORT=8000

# SUMO Configuration
SUMO_HOME=/usr/share/sumo
SUMO_BINARY=sumo
SUMO_GUI_BINARY=sumo-gui

# Model Configuration
MODEL_STORAGE_PATH=./models
CHECKPOINT_PATH=./models/checkpoints

# Training Configuration
DEVICE=cuda
BATCH_SIZE=32
LEARNING_RATE=0.001

# ======================
# Docker Configuration
# ======================
# Uncomment and set these if you need custom Docker settings
# COMPOSE_PROJECT_NAME=georgetown-traffic-ai
# DOCKER_BUILDKIT=1
# COMPOSE_DOCKER_CLI_BUILD=1
