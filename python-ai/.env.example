# Server Configuration
ENVIRONMENT=development
HOST=0.0.0.0
PORT=8000

# Database
MONGODB_URI=mongodb://localhost:27017/georgetown-traffic-ai

# Security
API_KEY=your-api-key-change-in-production
INTER_SERVICE_SECRET=your-inter-service-secret-change-in-production
IP_WHITELIST=
REQUEST_TIMEOUT=300

# SUMO Configuration
SUMO_HOME=/usr/share/sumo
SUMO_BINARY=sumo
SUMO_GUI_BINARY=sumo-gui

# Model Configuration
MODEL_STORAGE_PATH=./models
CHECKPOINT_PATH=./models/checkpoints

# Training Configuration
DEVICE=cuda
BATCH_SIZE=32
LEARNING_RATE=0.001

# Logging
LOG_LEVEL=INFO

